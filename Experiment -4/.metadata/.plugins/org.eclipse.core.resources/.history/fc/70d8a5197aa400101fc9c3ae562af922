package sample;

import java.util.Scanner;

interface Bank {

 void createAccount(String name, int accNo, double initialAmount);

 void creditAmount(int accNo, double amount);

 void debitAmount(int accNo, double amount);

 void transferAmount(int fromAcc, int toAcc, double amount);

 void miniStatement(int accNo);

 double rateOfInterest(); 

}

class SBI implements Bank {

 String name;

 int accNo;

 double balance;

 public void createAccount(String name, int accNo, double initialAmount) {

     this.name = name;

     this.accNo = accNo;

     this.balance = initialAmount;

     System.out.println("SBI Account created successfully for " + name + " with A/C No: " + accNo);

 }

 public void creditAmount(int accNo, double amount) {

     if (this.accNo == accNo) {

         balance += amount;

         System.out.println("Amount credited successfully. New Balance: " + balance);

     } else {

         System.out.println("Account not found.");

     }

 }

 public void debitAmount(int accNo, double amount) {

     if (this.accNo == accNo) {

         if (balance >= amount) {

             balance -= amount;

             System.out.println("Amount debited successfully. New Balance: " + balance);

         } else {

             System.out.println("Insufficient balance.");

         }

     } else {

         System.out.println("Account not found.");

     }

 }

public void transferAmount(int fromAcc, int toAcc, double amount) {

     if (this.accNo == fromAcc) {

         if (balance >= amount) {

             balance -= amount;

             System.out.println("Amount transferred from " + fromAcc + " to " + toAcc + " successfully.");

             System.out.println("New Balance: " + balance);

         } else {

             System.out.println("Insufficient balance.");

         }

     } else {

         System.out.println("From Account not found.");

     }

 }

public void miniStatement(int accNo) {

     if (this.accNo == accNo) {

         System.out.println("---- SBI Mini Statement ----");

         System.out.println("Name: " + name);

         System.out.println("Account No: " + this.accNo);

         System.out.println("Balance: " + balance);

     } else {

         System.out.println("Account not found.");

     }

 }

public double rateOfInterest() {

     return 5.5; 

 }

}

